# --- Global LLM Provider Selection ---
# Options: ollama, openai, gemini, groq
LLM_PROVIDER=ollama

# --- Per-Agent Provider Overrides ---
# สลับค่ายให้แต่ละ Agent ได้อิสระ (ถ้าไม่ใส่จะใช้ LLM_PROVIDER ด้านบน)
ORCHESTRATOR_PROVIDER=gemini
RESEARCH_PROVIDER=ollama
WRITER_PROVIDER=openai
ADVISOR_PROVIDER=groq
EDITOR_PROVIDER=gemini
IT_PROVIDER=ollama
HR_PROVIDER=ollama
QA_PROVIDER=ollama

# --- Local Ollama Settings ---
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma

# --- OpenAI Settings ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# --- Google Gemini Settings ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Groq Settings ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
